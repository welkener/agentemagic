# Magic BI — variáveis de ambiente (copie para .env e preencha)
# NUNCA commite o arquivo .env — segredos ficam fora do repositório.

# Django
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados
# Local rápido (padrão se ausente): sqlite:///db.sqlite3
# Docker Compose: postgres://magicbi:magicbi@postgres:5432/magicbi
DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# WhatsApp Cloud API (Meta for Developers)
META_APP_SECRET=segredo-do-app-meta
WHATSAPP_VERIFY_TOKEN=token-de-verificacao-do-webhook
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Groq API (function-calling barato/rápido — console.groq.com/keys)
# Sem a chave, o orquestrador cai no roteamento determinístico por palavra-chave.
GROQ_API_KEY=
