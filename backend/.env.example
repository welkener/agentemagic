# Magic BI — variáveis de ambiente (copie para .env e preencha)
# NUNCA commite o arquivo .env — segredos ficam fora do repositório.

# Django
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados — só Postgres (sqlite descontinuado)
# Local (padrão se ausente): postgres://postgres:123456@localhost:5432/magicbi
# Docker Compose: postgres://magicbi:magicbi@postgres:5432/magicbi
DATABASE_URL=postgres://postgres:123456@localhost:5432/magicbi

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# WhatsApp Cloud API (Meta for Developers)
META_APP_SECRET=segredo-do-app-meta
WHATSAPP_VERIFY_TOKEN=token-de-verificacao-do-webhook
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Groq API (function-calling barato/rápido — console.groq.com/keys)
# Sem a chave, o orquestrador cai no roteamento determinístico por palavra-chave.
GROQ_API_KEY=

# Chave de cifra dos segredos salvos via Django admin (Credencial/AplicativoIntegracao).
# Gere a sua: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
